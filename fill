<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="theme-color" content="#000000">
    <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate">
    
    <title>SKY HDTV TURBO</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;800;900&display=swap" rel="stylesheet">
    
    <style>
        :root {
            --bg-deep: #000000;
            --ferrari-red: #FF2800; 
            --font-xs: 1.8vh; --font-sm: 2.2vh; --font-md: 3vh; --font-lg: 5vh;
        }

        * { 
            margin: 0; padding: 0; box-sizing: border-box; outline: none; 
            -webkit-tap-highlight-color: transparent; -webkit-user-select: none; user-select: none;           
        }
        
        html, body {
            background: #000000; 
            color: #ffffff; font-family: 'Montserrat', sans-serif;
            position: fixed; top: 0; left: 0; width: 100%; height: 100%; 
            overflow: hidden !important;
            transform: translate3d(0,0,0); 
            -webkit-transform: translate3d(0,0,0);
            backface-visibility: hidden;
            -webkit-backface-visibility: hidden;
        }

        .hide { display: none !important; }
        .flex-center { display: flex; align-items: center; justify-content: center; }
        .layer { position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: 10; background: transparent; }

        button, .cat-item, .item, .toggle-btn, .key { cursor: pointer; }
        
        .cat-list, .item-list, .meta { 
            overflow-y: auto; 
            -webkit-overflow-scrolling: touch;
            transform: translateZ(0);
            will-change: transform;
        }

        #rotate-layer { display: none; background: #000; z-index: 99999; flex-direction: column; text-align: center; }
        .rotate-icon { font-size: 10vh; color: var(--ferrari-red); margin-bottom: 3vh; animation: rotate-phone 2s infinite ease-in-out; }
        .rotate-msg { font-size: 3vh; font-weight: 900; color: #fff; }
        @keyframes rotate-phone { 
            0%, 100% { transform: rotate(0deg); opacity: 0; } 
            25%, 50% { transform: rotate(-90deg); opacity: 1; } 
            75% { transform: rotate(-90deg); opacity: 0; } 
        }
        @media screen and (orientation: portrait) {
            #rotate-layer { display: flex !important; }
            #login-layer, #content-layer, #settings-layer, #loader { display: none !important; }
        }

        .focused { 
            border: 3px solid #ffffff !important; 
            background: var(--ferrari-red) !important; 
            color: #fff !important; 
            z-index: 50; 
            box-shadow: none !important;
            transform: none !important;
        }
        .focused i, .focused span, .focused div { color: #fff !important; }
        
        #vid-box.focused { border: 4px solid var(--ferrari-red) !important; background: transparent !important; }
        #vid-box.fs, #vid-box.fs.focused { border: none !important; width: 100% !important; height: 100% !important; z-index: 9999 !important; position: fixed !important; top: 0 !important; left: 0 !important; background: #000 !important; }

        .login-box { width: 450px; max-width: 90%; padding: 40px; background: #0a0a0a; border: 2px solid var(--ferrari-red); border-radius: 12px; text-align: center; }
        .logo-txt { font-size: 4.5vh; font-weight: 900; margin-bottom: 2.5vh; }
        .red-text { color: var(--ferrari-red); }
        .inp { width: 100%; padding: 16px; margin: 10px 0; background: #1a1a1a; border: 1px solid #333; color: #fff; text-align: center; font-weight: 600; border-radius: 8px; font-size: 16px; }
        .btn { width: 100%; padding: 16px; margin-top: 20px; background: var(--ferrari-red); color: #fff; border: none; font-weight: 900; border-radius: 8px; font-size: 16px; }
        .btn-logout { background: #333; color: #fff; margin-top: 10px; border: 1px solid #444; }

        .config-row { display: flex; gap: 1vw; margin: 2vh 0; }
        .toggle-btn { flex: 1; padding: 1.5vh; background: #1a1a1a; border: 1px solid #333; color: #888; font-size: var(--font-sm); font-weight: 800; border-radius: 1vh; }
        .info-row { display: flex; justify-content: space-between; padding: 1vh 0; border-bottom: 1px solid #222; font-size: var(--font-sm); color: #ccc; }

        #content-layer { display: flex; width: 100%; height: 100%; background: #000; }
        
        .col-cat { width: 25%; min-width: 25%; max-width: 25%; flex: 0 0 25%; background: #08080a; display: flex; flex-direction: column; border-right: 2px solid #1a1a1a; }
        .col-list { width: 35%; min-width: 35%; max-width: 35%; flex: 0 0 35%; background: #101014; display: flex; flex-direction: column; border-right: 2px solid #1a1a1a; }
        .col-play { width: 40%; min-width: 40%; max-width: 40%; flex: 0 0 40%; display: flex; flex-direction: column; position: relative; }

        .cat-head { padding: 15px; background: #15151a; color: var(--ferrari-red); border-bottom: 2px solid #222; text-align: center; font-size: var(--font-md); font-weight: 900; }
        .cat-top-row { display: flex; align-items: center; width: 100%; justify-content: center; }
        
        .cat-item, .item { padding: 14px 20px; border-radius: 6px; margin: 6px 12px; color: #888; font-size: var(--font-sm); font-weight: 700; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; border: 1px solid transparent; }
        .cat-item.active { background: #1a1a1a; color: #fff; border-left: 4px solid var(--ferrari-red); }
        
        .search-area { padding: 15px; background: #050505; border-bottom: 2px solid #1a1a1a; }
        .inp-search { width: 100%; padding: 12px; background: #111; border: 1px solid #333; color: #fff; font-size: var(--font-sm); font-weight: bold; border-radius: 6px; text-transform: uppercase; text-align: center; }
        
        .item { border-bottom: 1px solid #1a1a1a; }
        .item.playing { color: var(--ferrari-red); background: #111; border-left: 4px solid var(--ferrari-red); }
        .fav-icon { float: right; color: var(--ferrari-red); }

        .vid-box { width: 100%; height: 50vh; background: #000; position: relative; border-bottom: 2px solid #222; transform: translateZ(0); }
        #player-container { width: 100%; height: 100%; background: #000; }
        
        /* OTIMIZAÇÃO: Alterado de object-fit: contain para object-fit: fill */
        video { width: 100%; height: 100%; object-fit: fill; background: #000; }
        
        .buffer-overlay { position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.8); z-index: 50; display: none; flex-direction: column; align-items: center; justify-content: center; }
        
        @keyframes pulse-play {
            0% { transform: scale(0.9); opacity: 0.7; }
            50% { transform: scale(1.1); opacity: 1; text-shadow: 0 0 20px rgba(255, 40, 0, 0.8); }
            100% { transform: scale(0.9); opacity: 0.7; }
        }
        .play-wait-icon { font-size: 8vh; color: var(--ferrari-red); animation: pulse-play 1.5s infinite ease-in-out; }
        
        .meta { padding: 25px; flex: 1; background: #0a0a0c; display: flex; flex-direction: column; }
        .meta-title { font-size: var(--font-lg); color: var(--ferrari-red); font-weight: 900; margin-bottom: 1vh; }
        .meta-desc { font-size: var(--font-sm); color: #999; margin-bottom: 2vh; }
        
        .account-info-bar { display: flex; gap: 2vw; padding: 1.5vh; background: #111; border-radius: 1vh; border: 1px solid #222; margin-top: auto; margin-bottom: 2vh; justify-content: space-around; }
        .acc-item { display: flex; flex-direction: column; align-items: center; }
        .acc-lbl { font-size: 1.5vh; color: #666; font-weight: 700; margin-bottom: 0.5vh; }
        .acc-val { font-size: 2.2vh; color: #fff; font-weight: 900; }
        .acc-val i { color: var(--ferrari-red); margin-right: 5px; }

        .keys { display: flex; justify-content: space-between; align-items: center; gap: 1vw; padding-top: 2vh; border-top: 2px solid #1a1a1a; }
        .key { flex: 1; font-size: var(--font-xs); color: #fff; font-weight: 700; background: #1a1a1a; border: 1px solid #333; padding: 1.2vh 0.5vw; border-radius: 0.8vh; display: flex; align-items: center; justify-content: center; white-space: nowrap; }
        .dot { width: 1.2vh; height: 1.2vh; border-radius: 50%; flex-shrink: 0; margin-right: 1.2vw; }

        #loader { background: #000; z-index: 20000; flex-direction: column; color: var(--ferrari-red); font-weight: 900; font-size: var(--font-lg); }
        
        ::-webkit-scrollbar { width: 4px; }
        ::-webkit-scrollbar-thumb { background: #333; }
    </style>
</head>
<body onload="App.init()">

