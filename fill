    <script>
        function safePlay(vidElement) {
            if (!vidElement) return;
            try { 
                var p = vidElement.play(); 
                if (p !== undefined && typeof p.catch === 'function') { 
                    p.catch(function(e) {}); 
                } 
            } catch (e) {}
        }
        function requestNativeFullscreen(elem) {
            var target = elem || document.documentElement;
            try {
                if (target.requestFullscreen) { var p = target.requestFullscreen(); if(p !== undefined && typeof p.catch === 'function') { p.catch(function(){}); } } 
                else if (target.webkitRequestFullscreen) { target.webkitRequestFullscreen(); }
            } catch (e) {}
        }

        var FavManager = {
            key: 'rc_favs_smart', list: [],
            init: function() { var s = localStorage.getItem(this.key); this.list = s ? JSON.parse(s) : []; },
            toggle: function(id) {
                var idx = this.list.indexOf(id);
                if(idx > -1) this.list.splice(idx, 1); else this.list.push(id);
                localStorage.setItem(this.key, JSON.stringify(this.list));
                App.renderList(true);
            },
            isFav: function(id) { return this.list.indexOf(id) > -1; }
        };

        var PlayerEngine = {
            video: null, url: null, monitorTimer: null, lastTime: 0, stallCount: 0, retryCount: 0, isBuffering: false, maxRetries: 999999,

            init: function() { this.bindVideo(); },

            bindVideo: function() {
                this.video = document.getElementById('player'); 
                if(!this.video) return;
                this.video.onerror = function() { PlayerEngine.handleError(false); };
                this.video.onabort = function() { PlayerEngine.handleError(false); };
                this.video.onstalled = function() { PlayerEngine.showBuffer(); };
                this.video.onended = function() { PlayerEngine.handleError(false); };
                this.video.addEventListener('playing', function() { PlayerEngine.onPlaySuccess(); });
                this.video.addEventListener('waiting', function() { PlayerEngine.showBuffer(); });
                this.video.controls = false;
            },

            resetDOM: function() {
                if(this.video) {
                    this.video.pause();
                    this.video.removeAttribute('src'); 
                    this.video.load(); 
                }
            },

            play: function(url) {
                if(this.url === url && !this.video.error) {
                    if(this.video.paused) safePlay(this.video);
                    return;
                }
                if (this.url && this.url !== url) {
                    this.hardStop();
                    this.resetDOM(); 
                }
                this.url = url; this.stallCount = 0; this.retryCount = 0;
                this.showBuffer();
                
                if(this.video) {
                    this.video.src = url; 
                    safePlay(this.video);
                }
                this.startMonitor();
            },
            
            onPlaySuccess: function() { this.stallCount = 0; this.retryCount = 0; this.hideBuffer(); },
            showBuffer: function() { this.isBuffering = true; var el = document.getElementById('smart-buffer'); if(el) el.style.display = 'flex'; },
            hideBuffer: function() { this.isBuffering = false; var el = document.getElementById('smart-buffer'); if(el) el.style.display = 'none'; },
            
            startMonitor: function() {
                this.stopMonitor();
                this.monitorTimer = setInterval(function() {
                    var v = PlayerEngine.video; 
                    if(!v || !PlayerEngine.url || v.paused) return;
                    if(Math.abs(v.currentTime - PlayerEngine.lastTime) < 0.1) {
                        PlayerEngine.stallCount++;
                        if(PlayerEngine.stallCount > 3) PlayerEngine.showBuffer();
                        if(PlayerEngine.stallCount > 6) { PlayerEngine.stallCount = 0; PlayerEngine.handleError(true); }
                    } else { 
                        PlayerEngine.stallCount = 0; PlayerEngine.lastTime = v.currentTime; 
                        if(PlayerEngine.isBuffering) PlayerEngine.hideBuffer();
                    }
                }, 2000);
            },
            stopMonitor: function() { if(this.monitorTimer) clearInterval(this.monitorTimer); },
            
            handleError: function(isStall) {
                if (this.retryCount < this.maxRetries) {
                    this.retryCount++;
                    this.showBuffer();
                    this.resetDOM();
                    var delay = Math.min(1000 * Math.pow(1.5, this.retryCount), 5000);
                    setTimeout(function() { 
                        if(PlayerEngine.video) {
                            PlayerEngine.video.src = PlayerEngine.url;
                            safePlay(PlayerEngine.video);
                        }
                    }, delay);
                }
            },
            
            hardStop: function() { 
                this.stopMonitor(); 
                this.resetDOM();
                this.url = null;
                this.hideBuffer();
            }
        };

        var App = {
            validCategories: null, scr: 0, zone: 0, idx: 0, lastCatIdx: 0, creds: {}, fullData: [], globalData: null, playingId: null,
            cfg: { filter: false, format: 'ts_native', lang: 'pt' }, userInfo: null, lastEnter: 0, 
            sessionStartTime: null, refreshInterval: 12 * 60 * 60 * 1000, refreshTimer: null,
            lastFocusedEl: null, 

            i18n: {
                'en': { ph_dns: 'DNS URL', ph_user: 'USERNAME', ph_pass: 'PASSWORD', btn_login: 'CONNECT', load_init: 'STARTING...', load_auth: 'LOGGING IN...', load_net: 'NETWORK...', err_net: 'Connection Failed', err_auth: 'Invalid Login', set_title: 'MY ACCOUNT', set_u: 'USER:', set_e: 'EXP:', set_c: 'CONN:', set_d: 'DATE:', set_opt: 'OPTIONS', set_filter: 'BLOCK:', set_format: 'FMT:', set_lang: 'LANG:', set_back: 'BACK', yes: 'YES', no: 'NO', fmt_def: 'DEF', cat_title: 'CHANNELS', cat_fav: '⭐ FAV', search_ph: 'SEARCH...', empty: 'Empty', loading: 'LOADING...', osd_lost: 'NO SIGNAL', key_fs: 'FULLSCREEN (R)', key_top: 'TOP (G)', key_search: 'FIND (Y)', key_menu: 'CONFIG (B)', tot_chan: 'CH', tot_pre: 'TOTAL: ', unlimited: 'Unlimited', unknown: 'Unknown', flag: '🇺🇸 EN', btn_out: 'LOGOUT' },
                'pt': { ph_dns: 'URL DNS', ph_user: 'USUÁRIO', ph_pass: 'SENHA', btn_login: 'CONECTAR', load_init: 'INICIANDO...', load_auth: 'AUTENTICANDO...', load_net: 'REDE...', err_net: 'Falha Conexão', err_auth: 'Login Inválido', set_title: 'MINHA CONTA', set_u: 'USUÁRIO:', set_e: 'VENCE:', set_c: 'TELAS:', set_d: 'CRIADO:', set_opt: 'OPÇÕES', set_filter: 'XXX:', set_format: 'FMT:', set_lang: 'IDIOMA:', set_back: 'VOLTAR', yes: 'SIM', no: 'NÃO', fmt_def: 'PADRÃO', cat_title: 'CANAIS', cat_fav: '⭐ FAVORITOS', search_ph: 'BUSCAR...', empty: 'Vazio', loading: 'CARREGANDO...', osd_lost: 'SEM SINAL', key_fs: 'TELA CHEIA (R)', key_top: 'TOPO (G)', key_search: 'BUSCA (Y)', key_menu: 'CONFIG (B)', tot_chan: 'CANAIS', tot_pre: 'TOTAL: ', unlimited: 'Ilimitado', unknown: 'Desconhecido', flag: '🇧🇷 PT', btn_out: 'SAIR / DESLOGAR' },
                'es': { ph_dns: 'URL DNS', ph_user: 'USUARIO', ph_pass: 'CLAVE', btn_login: 'CONECTAR', load_init: 'INICIANDO...', load_auth: 'AUTENTICANDO...', load_net: 'RED...', err_net: 'Fallo Conexión', err_auth: 'Login Inválido', set_title: 'MI CUENTA', set_u: 'USUARIO:', set_e: 'VENCE:', set_c: 'PANTALLAS:', set_d: 'CREADO:', set_opt: 'OPCIONES', set_filter: 'XXX:', set_format: 'FMT:', set_lang: 'IDIOMA:', set_back: 'VOLVER', yes: 'SÍ', no: 'NO', fmt_def: 'DEFECTO', cat_title: 'CANALES', cat_fav: '⭐ FAVORITOS', search_ph: 'BUSCAR...', empty: 'Vacío', loading: 'CARGANDO...', osd_lost: 'SIN SEÑAL', key_fs: 'PANTALLA COMPLETA (R)', key_top: 'TOP (G)', key_search: 'BUSCA (Y)', key_menu: 'CONFIG (B)', tot_chan: 'CANALES', tot_pre: 'TOTAL: ', unlimited: 'Ilimitado', unknown: 'Desconocido', flag: '🇪🇸 ES', btn_out: 'SALIR' }
            },

            applyLang: function() {
                var t = this.i18n[this.cfg.lang];
                document.getElementById('i0').placeholder = t.ph_dns; document.getElementById('i1').placeholder = t.ph_user; document.getElementById('i2').placeholder = t.ph_pass; document.getElementById('i3').innerText = t.btn_login;
                document.getElementById('set-title-txt').innerHTML = '<i class="fas fa-user-shield" style="margin-right:10px; color: #FF2800;"></i>' + t.set_title;
                document.getElementById('lbl-set-u').innerText = t.set_u; document.getElementById('lbl-set-e').innerText = t.set_e; document.getElementById('lbl-set-c').innerText = t.set_c; document.getElementById('lbl-set-d').innerText = t.set_d;
                document.getElementById('s0').innerText = t.set_opt; document.getElementById('lbl-set-filter').innerText = t.set_filter; document.getElementById('lbl-set-format').innerText = t.set_format; document.getElementById('lbl-set-lang').innerText = t.set_lang; document.getElementById('s4').innerText = t.set_back; document.getElementById('s5').innerText = t.btn_out;
                
                document.getElementById('cat-title-txt').innerText = t.cat_title; document.getElementById('search').placeholder = t.search_ph;
                document.getElementById('key-fs').innerHTML = '<div class="dot" style="background-color:#FF0000; box-shadow: 0 0 10px #FF0000;"></div> ' + t.key_fs; 
                document.getElementById('key-top').innerHTML = '<div class="dot" style="background-color:#00C851; box-shadow: 0 0 10px #00C851;"></div> ' + t.key_top; 
                document.getElementById('key-search').innerHTML = '<div class="dot" style="background-color:#ffbb33; box-shadow: 0 0 10px #ffbb33;"></div> ' + t.key_search; 
                document.getElementById('key-menu').innerHTML = '<div class="dot" style="background-color:#33b5e5; box-shadow: 0 0 10px #33b5e5;"></div> ' + t.key_menu;
                this.updateCfgUI();
                if (this.scr === 2) { this.countGlobal(); var c0 = document.getElementById('c0'); if(c0) c0.innerText = t.cat_fav; }
            },

            init: function() {
                FavManager.init(); 
                if(localStorage.getItem('rc_cfg_filter')) this.cfg.filter = (localStorage.getItem('rc_cfg_filter') === 'true');
                this.cfg.format = 'ts_native';
                if(localStorage.getItem('rc_cfg_lang')) this.cfg.lang = localStorage.getItem('rc_cfg_lang'); else this.cfg.lang = 'pt'; 
                this.applyLang(); PlayerEngine.init();
                
                if(localStorage.getItem('rc_h')) {
                    document.getElementById('i0').value = localStorage.getItem('rc_h'); document.getElementById('i1').value = localStorage.getItem('rc_u'); document.getElementById('i2').value = localStorage.getItem('rc_p');
                    document.getElementById('loader').classList.remove('hide'); document.getElementById('load-txt').innerText = this.i18n[this.cfg.lang].load_init; App.login(true);
                } else { this.setScr(0); }
            },

            toggleCfg: function(type) { if(type === 'filter') { this.cfg.filter = !this.cfg.filter; localStorage.setItem('rc_cfg_filter', this.cfg.filter); } this.updateCfgUI(); },
            toggleFormat: function() { this.cfg.format = (this.cfg.format === 'ts_native') ? 'm3u8_native' : 'ts_native'; this.updateCfgUI(); },
            toggleLang: function() { var langs = ['en', 'pt', 'es']; this.cfg.lang = langs[(langs.indexOf(this.cfg.lang) + 1) % langs.length]; localStorage.setItem('rc_cfg_lang', this.cfg.lang); this.applyLang(); },
            updateCfgUI: function() { 
                var t = this.i18n[this.cfg.lang];
                document.getElementById('lbl-filter').innerText = this.cfg.filter ? t.yes : t.no; 
                document.getElementById('s2').style.borderColor = this.cfg.filter ? '#00C851' : '#333'; 
                document.getElementById('lbl-filter').style.color = this.cfg.filter ? '#00C851' : '#888'; 
                document.getElementById('lbl-format').innerText = (this.cfg.format === 'm3u8_native') ? "M3U8 NAT" : "TS NAT"; 
                document.getElementById('s3').style.borderColor = '#00C851'; document.getElementById('lbl-format').style.color = '#00C851'; 
                document.getElementById('lbl-lang').innerText = t.flag;
            },
            
            req: function(url, cb) { 
                var x = new XMLHttpRequest(); var cacheBuster = (url.indexOf('?') > -1 ? '&' : '?') + '_t=' + new Date().getTime(); 
                x.open("GET", url + cacheBuster, true); x.timeout = 20000; 
                x.onload = function() { if(x.status===200) { try{cb(JSON.parse(x.responseText));}catch(e){cb(null);} } else cb(null); }; 
                x.onerror = function(){ cb('ERR_NET'); }; x.send(); 
            },

            login: function(isAuto) {
                var h = document.getElementById('i0').value.trim(); var u = document.getElementById('i1').value.trim(); var p = document.getElementById('i2').value.trim();
                if(h.endsWith('/')) h = h.slice(0, -1); if(h.indexOf('http') === -1) h = 'http://' + h;
                if(!isAuto) { document.getElementById('loader').classList.remove('hide'); document.getElementById('load-txt').innerText = this.i18n[this.cfg.lang].load_auth; requestNativeFullscreen(document.documentElement); } 
                this.req(h+"/player_api.php?username="+u+"&password="+p, function(d){
                    document.getElementById('loader').classList.add('hide');
                    if(d === 'ERR_NET') { if(isAuto) { document.getElementById('loader').classList.remove('hide'); document.getElementById('load-txt').innerText = App.i18n[App.cfg.lang].load_net; setTimeout(function(){ App.login(true); }, 3000); } else { App.setScr(0); document.getElementById('msg-login').innerHTML = App.i18n[App.cfg.lang].err_net; } return; }
                    if(d && d.user_info && d.user_info.auth==1) {
                        App.creds={h:h,u:u,p:p}; localStorage.setItem('rc_h', h); localStorage.setItem('rc_u', u); localStorage.setItem('rc_p', p); 
                        var info = d.user_info; var exp = info.exp_date ? new Date(info.exp_date*1000).toLocaleDateString('pt-BR') : App.i18n[App.cfg.lang].unlimited; 
                        var conn = (info.active_cons || 0) + " / " + (info.max_connections || 1);
                        document.getElementById('set-user').innerText = info.username || u; document.getElementById('set-exp').innerText = exp; document.getElementById('set-conn').innerText = (info.max_connections || 1);
                        document.getElementById('meta-user').innerText = info.username || u; document.getElementById('meta-exp').innerText = exp; document.getElementById('meta-conn').innerText = conn;
                        App.openMode(); 
                    } else { App.setScr(0); document.getElementById('msg-login').innerText = App.i18n[App.cfg.lang].err_auth; localStorage.clear(); }
                });
            },
            logout: function() { PlayerEngine.hardStop(); localStorage.clear(); location.reload(); },

            setScr: function(n) {
                var layers = document.querySelectorAll('.layer'); for(var i=0; i<layers.length; i++) layers[i].classList.add('hide');
                if(n===0) document.getElementById('login-layer').classList.remove('hide');
                if(n===2) { document.getElementById('content-layer').classList.remove('hide'); this.page = 0; }
                if(n===3) document.getElementById('settings-layer').classList.remove('hide');
                this.scr=n; this.zone=0; this.idx=0; this.updateFocus();
            },

            openSettings: function() { this.setScr(3); this.idx = 0; this.updateFocus(); requestNativeFullscreen(); },
            closeSettings: function() { App.openMode('live'); },
            countGlobal: function() { if(document.getElementById('item-count')) document.getElementById('item-count').innerText = App.i18n[App.cfg.lang].tot_pre + (this.globalData ? this.globalData.length : 0); },

            openMode: function() {
                PlayerEngine.hardStop(); requestNativeFullscreen();
                this.playingId = null; this.page = 0; this.setScr(2);
                var t = App.i18n[App.cfg.lang]; document.getElementById('cat-list').innerHTML = ''; document.getElementById('item-list').innerHTML = ''; 
                
                this.req(this.creds.h+"/player_api.php?username="+this.creds.u+"&password="+this.creds.p+"&action=get_live_categories", function(d){
                    if(d && d!=='ERR_NET') {
                        var h = ['<div class="cat-item" id="c0" data-id="fav" onclick="App.catClick(0)">' + t.cat_fav + '</div>'];
                        for(var i=0;i<d.length;i++) h.push('<div class="cat-item" id="c'+(i+1)+'" data-id="'+d[i].category_id+'" onclick="App.catClick('+(i+1)+')">'+d[i].category_name+'</div>'); 
                        document.getElementById('cat-list').innerHTML = h.join('');
                        App.zone=0; App.idx=0; App.updateFocus();
                    }
                });
                this.req(this.creds.h+"/player_api.php?username="+this.creds.u+"&password="+this.creds.p+"&action=get_live_streams", function(d){ if(d && d!=='ERR_NET') { App.globalData = d; App.countGlobal(); } });
            },
            
            catClick: function(i) { this.idx=i; this.zone=0; this.loadContent(i); },

            loadContent: function(catIdx) {
                this.lastCatIdx = catIdx; var el = document.getElementById('c'+catIdx); if(!el) return;
                var cid = el.getAttribute('data-id'); 
                if(this.lastActiveCat) this.lastActiveCat.classList.remove('active');
                el.classList.add('active'); this.lastActiveCat = el;
                
                var t = App.i18n[App.cfg.lang]; document.getElementById('item-list').innerHTML = '<div style="padding:20px;text-align:center;">'+t.loading+'</div>';
                
                var onData = function(d) { 
                    if(d && d!=='ERR_NET') { App.fullData = d; App.renderList(); } 
                    else { document.getElementById('item-list').innerHTML = '<div style="padding:20px;text-align:center;">'+t.empty+'</div>'; }
                };

                if(cid === 'fav') {
                     this.req(this.creds.h+"/player_api.php?username="+this.creds.u+"&password="+this.creds.p+"&action=get_live_streams", function(d){ 
                         if(d && d!=='ERR_NET') onData(d.filter(function(x){ return FavManager.isFav(x.stream_id || x.series_id || x.id); }));
                     });
                } else { this.req(this.creds.h+"/player_api.php?username="+this.creds.u+"&password="+this.creds.p+"&action=get_live_streams&category_id="+cid, onData); }
            },

            renderList: function(keepIdx) {
                var d = this.fullData; var max = d.length; var t = App.i18n[App.cfg.lang];
                if(max===0) { document.getElementById('item-list').innerHTML = '<div style="padding:20px;text-align:center;">'+t.empty+'</div>'; return; }
                
                var h = [];
                var limit = Math.min(max, 150); 
                for(var i = 0; i < limit; i++) {
                    var n = d[i].name || d[i].title; var id = d[i].stream_id || d[i].series_id || d[i].id;
                    var icn = FavManager.isFav(id) ? '<i class="fas fa-star fav-icon"></i>' : '';
                    h.push('<div class="item" id="row-'+i+'" onclick="App.itemClick('+i+')">'+n+icn+'</div>');
                }
                document.getElementById('item-list').innerHTML = h.join(''); 
                this.zone = 2; if(!keepIdx) this.idx = 0; this.updateFocus();
            },

            itemClick: function(i) { this.idx=i; this.zone=2; var item = this.fullData[this.idx]; if(item) this.playStream(item); },

            playStream: function(item) {
                var id = item.stream_id || item.id; 
                var ext = (this.cfg.format === 'm3u8_native') ? 'm3u8' : 'ts';
                var url = this.creds.h+"/live/"+this.creds.u+"/"+this.creds.p+"/"+id+"."+ext;
                
                this.playingId = id; document.getElementById('meta-title').innerText = item.name || item.title; 
                PlayerEngine.play(url); 
                
                if(this.lastPlayingRow) this.lastPlayingRow.classList.remove('playing');
                var r = document.getElementById('row-'+this.idx); if(r) { r.classList.add('playing'); this.lastPlayingRow = r; }
            },

            updateFocus: function() {
                if (this.lastFocusedEl) { this.lastFocusedEl.classList.remove('focused'); }
                var el;
                if(this.scr===0) el=document.getElementById('i'+this.idx); 
                if(this.scr===3) el=document.getElementById('s'+this.idx);
                if(this.scr===2) { 
                    if(this.zone===0) el=document.getElementById('c'+this.idx); 
                    if(this.zone===1) el=document.getElementById('search'); 
                    if(this.zone===2) el=document.getElementById('row-'+this.idx); 
                    if(this.zone===3) el=document.getElementById('vid-box'); 
                }
                if(el) { 
                    el.classList.add('focused'); 
                    this.lastFocusedEl = el;
                    if(el.tagName==='INPUT') { el.focus(); } else { if(document.activeElement && document.activeElement.tagName==='INPUT') document.activeElement.blur(); el.focus(); } 
                    if(el.tagName!=='INPUT') {
                        var p = el.parentElement;
                        if(p) p.scrollTop = el.offsetTop - (p.clientHeight / 2) + (el.clientHeight / 2);
                    }
                }
            },
            
            move: function(d) {
                if(this.scr===0) { if(d===1 && this.idx < 3) this.idx++; if(d===0 && this.idx > 0) this.idx--; }
                if(this.scr===3) { 
                    if(this.idx === 0 && d===1) this.idx = 1; else if(this.idx > 0 && this.idx < 5 && d===1) this.idx++; else if(this.idx > 0 && d===0) this.idx--; 
                }
                if(this.scr===2) {
                    if(this.zone===3) { if(d===2) { this.zone=2; this.updateFocus(); } return; }
                    if(this.zone===0) { var max = document.getElementById('cat-list').children.length-1; if(d===1 && this.idx<max) this.idx++; if(d===0 && this.idx>0) this.idx--; if(d===3) { this.zone=2; this.idx=0; } }
                    else if(this.zone===2) { 
                        var dataLen = App.fullData.length;
                        if(d===1 && this.idx < dataLen - 1) this.idx++; else if(d===0 && this.idx > 0) this.idx--; else if(d===0 && this.idx === 0) this.zone = 1; 
                        else if(d===2) { this.zone=0; this.idx=this.lastCatIdx; } else if(d===3) this.zone=3;
                    }
                    else if(this.zone===1) { if(d===1) { this.zone=2; this.idx=0; } if(d===2) { this.zone=0; this.idx=this.lastCatIdx; } }
                }
                this.updateFocus();
            },

            enter: function() {
                var now = new Date().getTime(); if(now - this.lastEnter < 250) return; this.lastEnter = now;
                if(this.scr===0) { if(this.idx === 3) this.login(false); else if(this.idx < 3) this.move(1); }
                if(this.scr===3) { if(this.idx === 1) this.toggleLang(); if(this.idx === 2) this.toggleCfg('filter'); if(this.idx === 3) this.toggleFormat(); if(this.idx === 4) this.closeSettings(); if(this.idx === 5) this.logout(); }
                if(this.scr===2) {
                    if(this.zone===0) this.catClick(this.idx); 
                    if(this.zone===2) { var item = this.fullData[this.idx]; if(item) this.playStream(item); } 
                    if(this.zone===3) { var b = document.getElementById('vid-box'); if(b.classList.contains('fs')) { b.classList.remove('fs'); } else { b.classList.add('fs'); } } 
                }
            },
            
            handleVideoTap: function(e) {
                e.preventDefault(); 
                if(!App.playingId) return; 
                var b = document.getElementById('vid-box'); 
                if(b.classList.contains('fs')) b.classList.remove('fs'); 
                else b.classList.add('fs');
            }
        };

        // CONTROLES UNIVERSAIS E PHILCO MTK
        document.addEventListener('keydown', function(e) {
            var k = e.keyCode;
            
            var isLeft = (k===37);
            var isUp = (k===38);
            var isRight = (k===39);
            var isDown = (k===40);
            var isEnter = (k===13 || k===295); 
            var isBack = (k===8 || k===27 || k===461 || k===10009 || k===88); 
            
            var isRed = (k===403 || k===82); 
            var isGreen = (k===404 || k===71); 
            var isYellow = (k===405 || k===89); 
            var isBlue = (k===406 || k===66 || k===275); 

            if(isLeft) { e.preventDefault(); App.move(2); } 
            if(isUp) { e.preventDefault(); App.move(0); } 
            if(isRight) { e.preventDefault(); App.move(3); } 
            if(isDown) { e.preventDefault(); App.move(1); }
            if(isEnter) { e.preventDefault(); App.enter(); } 
            
            if(isBack) { 
                e.preventDefault(); 
                if(document.getElementById('vid-box').classList.contains('fs')) { 
                    document.getElementById('vid-box').classList.remove('fs'); 
                } else if(App.scr===3) { 
                    App.closeSettings(); 
                } 
            }
            
            if(isRed && App.scr===2) { e.preventDefault(); var b = document.getElementById('vid-box'); if(b.classList.contains('fs')) b.classList.remove('fs'); else b.classList.add('fs'); }
            if(isGreen && App.scr===2) { e.preventDefault(); App.zone=0; App.idx=0; App.updateFocus(); }
            if(isYellow && App.scr===2) { e.preventDefault(); App.zone=1; App.updateFocus(); }
            if(isBlue) { e.preventDefault(); App.openSettings(); }
        });
    </script>
</body>
</html>
